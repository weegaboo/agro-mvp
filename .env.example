# ------------------------------
# Ports
# ------------------------------
WEB_PORT=3000
API_PORT=8000
POSTGRES_PORT=5432
WEB_BIND_ADDRESS=0.0.0.0
API_BIND_ADDRESS=0.0.0.0
POSTGRES_BIND_ADDRESS=127.0.0.1

# ------------------------------
# Database
# ------------------------------
POSTGRES_DB=agro
POSTGRES_USER=agro
POSTGRES_PASSWORD=agro
POSTGRES_HOST=db
POSTGRES_INTERNAL_PORT=5432

# ------------------------------
# API auth
# ------------------------------
JWT_SECRET_KEY=change-me-in-prod
ACCESS_TOKEN_EXPIRE_MINUTES=120

# ------------------------------
# Web -> API URL
# Local (docker on laptop): http://localhost:8000
# Server (public IP/domain): http://SERVER_IP:8000 or https://your-domain
# ------------------------------
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# ------------------------------
# CORS origins for API (comma-separated)
# Local example: http://localhost:3000,http://127.0.0.1:3000
# Server example: http://SERVER_IP:3000,https://your-domain
# ------------------------------
API_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
